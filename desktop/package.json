{
  "name": "dayloop",
  "version": "1.0.0",
  "description": "Day Loop — your AI dashboard",
  "main": "src/main.js",
  "author": "Marvin",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --arm64 --x64",
    "build:arm": "electron-builder --mac --arm64",
    "build:intel": "electron-builder --mac --x64"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.dayloop.app",
    "productName": "Day Loop",
    "copyright": "Copyright © 2026 Day Loop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "extendInfo": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "com.dayloop.app",
            "CFBundleURLSchemes": ["dayloop"]
          }
        ]
      }
    },
    "dmg": {
      "title": "Day Loop",
      "background": "assets/dmg-background.png",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 180, "type": "file" },
        { "x": 400, "y": 180, "type": "link", "path": "/Applications" }
      ]
    },
    "protocols": [
      {
        "name": "Day Loop",
        "schemes": ["dayloop"]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "malvidah",
        "repo": "lifeos",
        "releaseType": "release"
      }
    ]
  }
}
