{
    "name": "daylab",
    "version": "1.0.2",
    "description": "Day Lab \u2014 your AI dashboard",
    "main": "src/main.js",
    "author": "Marvin",
    "private": true,
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --mac --arm64 --x64",
        "build:arm": "electron-builder --mac --arm64",
        "build:intel": "electron-builder --mac --x64"
    },
    "devDependencies": {
        "electron": "^29.0.0",
        "electron-builder": "^24.0.0"
    },
    "build": {
        "appId": "com.daylab.app",
        "productName": "Day Lab",
        "copyright": "Copyright \u00a9 2026 Day Lab",
        "directories": {
            "output": "dist"
        },
        "files": [
            "src/**/*"
        ],
        "mac": {
            "category": "public.app-category.productivity",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.icns",
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "entitlements": "assets/entitlements.mac.plist",
            "entitlementsInherit": "assets/entitlements.mac.plist",
            "extendInfo": {
                "CFBundleURLTypes": [
                    {
                        "CFBundleURLName": "com.daylab.app",
                        "CFBundleURLSchemes": [
                            "daylab"
                        ]
                    }
                ]
            }
        },
        "dmg": {
            "title": "Day Lab",
            "background": "assets/dmg-background.png",
            "window": {
                "width": 540,
                "height": 380
            },
            "contents": [
                {
                    "x": 140,
                    "y": 180,
                    "type": "file"
                },
                {
                    "x": 400,
                    "y": 180,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "protocols": [
            {
                "name": "Day Lab",
                "schemes": [
                    "daylab"
                ]
            }
        ],
        "publish": [
            {
                "provider": "github",
                "owner": "malvidah",
                "repo": "lifeos",
                "releaseType": "release"
            }
        ],
        "afterSign": "notarize.js"
    }
}